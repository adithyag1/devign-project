{
    "create": {
        "filter_column_value": {"project": "qemu"},
        "slice_size": 100,
        "joern_cli_dir": "joern/joern-cli/"
    },
    "paths": {
        "cpg": "data/cpg/",
        "joern": "data/joern/",
        "raw": "data/raw/",
        "input": "data/input/",
        "model": "data/model/"
    },
    "files": {
        "raw": "dataset.json",
        "cpg": "cpg",
        "input": "input.pkl",
        "model": "checkpoint.pt"
    },
    "embed": {
        "codebert_dim": 768,
        "node_type_dim": 1,
        "graph_features_dim": 6,
        "feature_dim": 775
    },
    "process": {
        "epochs": 50,
        "patience": 20,
        "batch_size": 32,
        "learning_rate": 5e-3,
        "weight_decay": 1e-5,
        "weight_0": 0.8,
        "weight_1": 1.5,
        "shuffle": true,
        "accumulation_steps": 2,
        "warmup_epochs": 3
    }
}
